# Server-only. Never expose with a NEXT_PUBLIC_ prefix.
ANTHROPIC_API_KEY=

# Pinned low-cost default selected in Phase 2; override only after fixture evidence.
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Server-only QA switch. Keep false in production unless preview URLs are intentional.
CVLENS_ENABLE_PREVIEW_STATES=false

# Public site origin used for absolute OpenGraph/Twitter metadata and the OG image URL.
# Set to the deployed Railway URL in production; defaults to http://localhost:3000.
CVLENS_SITE_URL=https://cvlens.up.railway.app
